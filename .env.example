# Harbor Satellite
# This file is read by cmd/harbor-satellite via .env.harbor-satellite or .env.

# Ground Control registration.
# TOKEN is required unless SPIFFE_ENABLED=true.
GROUND_CONTROL_URL=http://127.0.0.1:8080
TOKEN=

# TLS/SPIFFE registration.
USE_UNSECURE=false
SPIFFE_ENABLED=false
SPIFFE_ENDPOINT_SOCKET=unix:///run/spire/sockets/agent.sock
SPIFFE_EXPECTED_SERVER_ID=

# Local/external registry configuration.
BYO_REGISTRY=false
REGISTRY_URL=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
REGISTRY_DATA_DIR=

# Local config and shutdown behavior.
CONFIG_DIR=
SHUTDOWN_TIMEOUT=30s

# CRI registry fallback and Harbor registry override.
NO_REGISTRY_FALLBACK=false
HARBOR_REGISTRY_URL=

# Experimental direct delivery.
DIRECT_DELIVERY=false
IMAGE_DIR=

# Optional PARSEC hardware-backed identity.
PARSEC_ENABLED=false
PARSEC_SOCKET=/run/parsec/parsec.sock
