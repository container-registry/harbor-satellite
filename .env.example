# Harbor Satellite
# Copy this file to .env. Both cmd/groundcontrol/server and cmd/satellite read .env.

# Ground Control registration.
# TOKEN is required unless SPIFFE_ENABLED=true.
GROUND_CONTROL_URL=http://127.0.0.1:8080
TOKEN=

# TLS/SPIFFE registration.
USE_UNSECURE=false
SPIFFE_ENABLED=false
SPIFFE_ENDPOINT_SOCKET=unix:///run/spire/sockets/agent.sock
SPIFFE_EXPECTED_SERVER_ID=

# Local/external registry configuration.
BYO_REGISTRY=false
REGISTRY_URL=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
REGISTRY_DATA_DIR=

# Local config and shutdown behavior.
CONFIG_DIR=
SHUTDOWN_TIMEOUT=30s

# CRI registry fallback and Harbor registry override.
NO_REGISTRY_FALLBACK=false
HARBOR_REGISTRY_URL=

# Experimental direct delivery.
DIRECT_DELIVERY=false
IMAGE_DIR=

# Optional PARSEC hardware-backed identity.
PARSEC_ENABLED=false
PARSEC_SOCKET=/run/parsec/parsec.sock

# Ground Control

# Harbor source registry.
HARBOR_URL=
HARBOR_USERNAME=
HARBOR_PASSWORD=

# Robot account expiry in days. Invalid, zero, and negative values fall back to 30.
ROBOT_DURATION_DAYS=30

# WARNING: TESTING/DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION.
# Skips Harbor health checks and uses placeholder credentials/state in SPIFFE flows.
SKIP_HARBOR_HEALTH_CHECK=false

# HTTP server and initial system admin.
PORT=8080
ADMIN_PASSWORD=

# User authentication policy.
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=false
SESSION_DURATION=24h
LOCKOUT_DURATION=5m

# Satellite status freshness threshold.
STALE_THRESHOLD=1h

# PostgreSQL.
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# TLS configuration.
# If TLS_CERT_FILE and TLS_KEY_FILE are set, HTTPS is enabled.
TLS_CERT_FILE=
TLS_KEY_FILE=
# Set TLS_CA_FILE to enable mutual TLS with client certificate verification.
TLS_CA_FILE=

# SPIFFE/SPIRE for Ground Control mTLS.
SPIFFE_SERVER_ENABLED=false
# SPIFFE_PROVIDER can be sidecar (SPIRE agent Workload API) or static
# (cert/key/bundle files).
SPIFFE_TRUST_DOMAIN=harbor-satellite.local
SPIFFE_PROVIDER=sidecar
SPIFFE_CERT_FILE=
SPIFFE_KEY_FILE=
SPIFFE_BUNDLE_FILE=

# Embedded SPIRE server. When enabled, Ground Control starts a local SPIRE
# server process and uses SPIRE_DATA_DIR/SPIRE_TRUST_DOMAIN/SPIRE_BIND_ADDRESS.
EMBEDDED_SPIRE_ENABLED=false
SPIRE_DATA_DIR=/tmp/spire-data
SPIRE_TRUST_DOMAIN=harbor-satellite.local
SPIRE_BIND_ADDRESS=127.0.0.1

# External SPIRE server. Used when EMBEDDED_SPIRE_ENABLED=false and
# SPIRE_SERVER_SOCKET is set. Address/port are returned to satellite
# registration clients as SPIRE agent bootstrap metadata.
SPIRE_SERVER_SOCKET=
SPIRE_SERVER_ADDRESS=spire-server
SPIRE_SERVER_PORT=8081

# Audit logging for security events.
# Set AUDIT_LOG_ENABLED=true to emit authentication, registration, user
# management, and policy events as RFC 5424 syslog messages and/or OTel logs.
# AUDIT_SYSLOG_ENABLED=true keeps the syslog transport on by default; set it to
# false to export only over OpenTelemetry (requires AUDIT_OTEL_ENDPOINT). When
# auditing is enabled, turning off both transports fails fast at startup.
# AUDIT_SYSLOG_TARGET selects the destination: daemon | network | file.
#   daemon  -> local syslog daemon at AUDIT_SYSLOG_SOCKET_PATH
#   network -> remote SIEM at AUDIT_SYSLOG_ADDRESS over AUDIT_SYSLOG_NETWORK
#   file    -> rotated local file at AUDIT_SYSLOG_FILE_PATH
# When AUDIT_TRUST_FORWARDED_HEADERS=true, source_ip is taken from
# X-Forwarded-For / X-Real-IP. Leave false unless GC sits behind a trusted
# reverse proxy; otherwise clients can spoof the audit source IP.
AUDIT_LOG_ENABLED=false
AUDIT_SYSLOG_ENABLED=true
AUDIT_SYSLOG_TARGET=file
AUDIT_SYSLOG_TAG=harbor-audit
AUDIT_SYSLOG_SOCKET_PATH=/dev/log
AUDIT_SYSLOG_NETWORK=udp
AUDIT_SYSLOG_ADDRESS=
AUDIT_SYSLOG_FILE_PATH=./audit.log
AUDIT_SYSLOG_FILE_MAX_SIZE_MB=100
AUDIT_SYSLOG_FILE_MAX_BACKUPS=7
AUDIT_SYSLOG_FILE_MAX_AGE_DAYS=30
AUDIT_SYSLOG_FILE_COMPRESS=true

# OTLP/HTTP collector base URL, for example http://127.0.0.1:4318.
# Empty disables the OTel transport.
AUDIT_OTEL_ENDPOINT=
AUDIT_TRUST_FORWARDED_HEADERS=false
