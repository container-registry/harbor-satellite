# Source Registry
HARBOR_USERNAME=
HARBOR_PASSWORD=
HARBOR_URL=
# Ground Control PORT
PORT=8080

# Robot account expiry in days (default: 30)
ROBOT_DURATION_DAYS=30

# WARNING: TESTING/DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION
# Skip Harbor health checks and use placeholder credentials
# SKIP_HARBOR_HEALTH_CHECK=true

DB_HOST=
DB_PORT=
DB_DATABASE=
# Customize user and pass based on your config
DB_USERNAME=
DB_PASSWORD=

# TLS Configuration (optional)
# If TLS_CERT_FILE and TLS_KEY_FILE are set, HTTPS will be enabled
TLS_CERT_FILE=
TLS_KEY_FILE=
# Set TLS_CA_FILE to enable mutual TLS (client certificate verification)
TLS_CA_FILE=

# Audit logging for security events (optional, disabled by default)
# Set AUDIT_LOG_ENABLED=true to write authentication, registration, user
# management, and policy events to a structured JSON log with rotation.
# When AUDIT_TRUST_FORWARDED_HEADERS=true, source_ip is taken from
# X-Forwarded-For / X-Real-IP. Leave false unless GC sits behind a trusted
# reverse proxy; otherwise clients can spoof the audit source IP.
AUDIT_LOG_ENABLED=false
AUDIT_LOG_MAX_AGE_DAYS=30
AUDIT_LOG_MAX_BACKUPS=7
AUDIT_LOG_MAX_SIZE_MB=100
AUDIT_LOG_PATH=./audit.log
AUDIT_TRUST_FORWARDED_HEADERS=false
