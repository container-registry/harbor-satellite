# Source Registry
HARBOR_USERNAME=
HARBOR_PASSWORD=
HARBOR_URL=
# Ground Control PORT
PORT=8080

# Robot account expiry in days (default: 30)
ROBOT_DURATION_DAYS=30

# WARNING: TESTING/DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION
# Skip Harbor health checks and use placeholder credentials
# SKIP_HARBOR_HEALTH_CHECK=true

DB_HOST=
DB_PORT=
DB_DATABASE=
# Customize user and pass based on your config
DB_USERNAME=
DB_PASSWORD=

# TLS Configuration (optional)
# If TLS_CERT_FILE and TLS_KEY_FILE are set, HTTPS will be enabled
TLS_CERT_FILE=
TLS_KEY_FILE=
# Set TLS_CA_FILE to enable mutual TLS (client certificate verification)
TLS_CA_FILE=

# Audit logging for security events (optional, disabled by default)
# Set AUDIT_LOG_ENABLED=true to emit authentication, registration, user
# management, and policy events as RFC 5424 syslog messages.
# AUDIT_SYSLOG_TARGET selects the destination: daemon | network | file.
#   daemon  -> local syslog daemon at AUDIT_SYSLOG_SOCKET_PATH (default /dev/log)
#   network -> remote SIEM at AUDIT_SYSLOG_ADDRESS over AUDIT_SYSLOG_NETWORK (udp/tcp)
#   file    -> rotated local file at AUDIT_SYSLOG_FILE_PATH (rotation knobs below)
# When AUDIT_TRUST_FORWARDED_HEADERS=true, source_ip is taken from
# X-Forwarded-For / X-Real-IP. Leave false unless GC sits behind a trusted
# reverse proxy; otherwise clients can spoof the audit source IP.
AUDIT_LOG_ENABLED=false
AUDIT_SYSLOG_TARGET=file
AUDIT_SYSLOG_TAG=harbor-audit
AUDIT_SYSLOG_SOCKET_PATH=/dev/log
AUDIT_SYSLOG_NETWORK=udp
AUDIT_SYSLOG_ADDRESS=
AUDIT_SYSLOG_FILE_PATH=./audit.log
AUDIT_SYSLOG_FILE_MAX_SIZE_MB=100
AUDIT_SYSLOG_FILE_MAX_BACKUPS=7
AUDIT_SYSLOG_FILE_MAX_AGE_DAYS=30
AUDIT_SYSLOG_FILE_COMPRESS=true
AUDIT_TRUST_FORWARDED_HEADERS=false
